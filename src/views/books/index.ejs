<!-- ========================= -->
<!-- FILTERS & SORTING FORM -->
<!-- ========================= -->
<form method="GET" action="/books" class="filters">

  <div class="filter-row">
    <!-- Title filter -->
    <input
      type="text"
      name="title"
      placeholder="Search Title"
      value="<%= title || '' %>"
    />

    <!-- ISBN filter -->
    <input
      type="text"
      name="isbn"
      placeholder="Search ISBN"
      value="<%= isbn || '' %>"
    />

    <!-- Rating filter -->
    <select name="rating">
      <option value="">All Ratings</option>
      <option value="1" <%= rating == 1 ? 'selected' : '' %>>1</option>
      <option value="2" <%= rating == 2 ? 'selected' : '' %>>2</option>
      <option value="3" <%= rating == 3 ? 'selected' : '' %>>3</option>
      <option value="4" <%= rating == 4 ? 'selected' : '' %>>4</option>
      <option value="5" <%= rating == 5 ? 'selected' : '' %>>5</option>
    </select>

    <!-- Finished After -->
    <input
      type="date"
      name="finished_after"
      value="<%= finished_after || '' %>"
    />
  </div>

  <div class="filter-row">
    <!-- Sort Field -->
    <select name="sort">
      <option value="">Sort By</option>
      <option value="title" <%= sort === 'title' ? 'selected' : '' %>>Title</option>
      <option value="rating" <%= sort === 'rating' ? 'selected' : '' %>>Rating</option>
      <option value="isbn" <%= sort === 'isbn' ? 'selected' : '' %>>ISBN</option>
      <option value="finished_date" <%= sort === 'finished_date' ? 'selected' : '' %>>
        Finished Date
      </option>
      <option value="created_at" <%= sort === 'created_at' ? 'selected' : '' %>>
        Created At
      </option>
      <option value="notes" <%= sort === 'notes' ? 'selected' : '' %>>Notes</option>
    </select>

    <!-- Asc / Desc -->
    <select name="order">
      <option value="asc" <%= order === 'asc' ? 'selected' : '' %>>Ascending</option>
      <option value="desc" <%= order === 'desc' ? 'selected' : '' %>>Descending</option>
    </select>
    <!-- Books Per Page -->
    <select name="limit">
      <option value="5" <%= limit == 5 ? 'selected' : '' %>>5 per page</option>
      <option value="10" <%= limit == 10 ? 'selected' : '' %>>10 per page</option>
      <option value="20" <%= limit == 20 ? 'selected' : '' %>>20 per page</option>
      <option value="50" <%= limit == 50 ? 'selected' : '' %>>50 per page</option>
    </select>
    <button type="submit">Apply</button>
  </div>

</form>

<hr />

<!-- ========================= -->
<!-- BOOKS LIST -->
<!-- ========================= -->
<div class="book-list">

  <% if (books.length === 0) { %>
    <p>No books found.</p>
  <% } %>

  <% books.forEach(book => { %>
    <div class="book-row">

      <div class="book-cover">
        <% if (book.coverUrl) { %>
          <img src="<%= book.coverUrl %>" alt="Book Cover" />
        <% } else { %>
          <div class="no-cover">No Cover</div>
        <% } %>
      </div>

      <div class="book-info">

        <h3 class="book-title"><%= book.title %></h3>
        
        <div class="book-meta">
    <div><strong>ISBN:</strong> <%= book.isbn || 'N/A' %></div>
    <div><strong>Rating:</strong> <%= book.rating || 'N/A' %></div>

    <%
      const finishedDate = book.finished_date
        ? new Date(book.finished_date).toLocaleDateString("en-US")
        : "N/A";
    %>

    <div><strong>Finished:</strong> <%= finishedDate %></div>
  </div>

  <% if (book.notes) { %>
    <div class="book-notes">
      <strong>Notes:</strong>
      <p><%= book.notes %></p>
    </div>
  <% } %>

        <div class="book-actions">
          <a class="btn" href="/books/<%= book.id %>/edit">Edit</a>

          <!-- DELETE FORM -->
          <form 
            action="/books/<%= book.id %>/delete" 
            method="POST"
            class="inline-form"
            onsubmit="return confirmDelete()"
          >
          <button type="submit" class="btn btn-danger">Delete</button>
          </form>
        </div>

      </div>

    </div>
  <% }) %>

</div>


<hr />

<!-- ========================= -->
<!-- PAGINATION -->
<!-- ========================= -->
<div class="pagination">

  <!-- Previous -->
  <% if (page > 1) { %>
    <a href="?<%= new URLSearchParams({ ...query, page: page - 1 }).toString() %>">
      Previous
    </a>
  <% } else { %>
    <span class="disabled">Previous</span>
  <% } %>

  <!-- Page Numbers -->
  <% for (let i = 1; i <= totalPages; i++) { %>
    <% if (i === page) { %>
      <span class="current-page"><%= i %></span>
    <% } else { %>
      <a href="?<%= new URLSearchParams({ ...query, page: i }).toString() %>">
        <%= i %>
      </a>
    <% } %>
  <% } %>

  <!-- Next -->
  <% if (page < totalPages) { %>
    <a href="?<%= new URLSearchParams({ ...query, page: page + 1 }).toString() %>">
      Next
    </a>
  <% } else { %>
    <span class="disabled">Next</span>
  <% } %>

</div>